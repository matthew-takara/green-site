---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Get in touch with Matthew Takara.">
  <h1>Contact</h1>

  <p>The best ways to reach me:</p>

  <ul class="contact-list" role="list">
    <li>
      <span class="label">Email</span>
      <a href="mailto:matthewtakara@gmail.com">matthewtakara@gmail.com</a>
    </li>
    <li>
      <span class="label">GitHub</span>
      <a href="https://github.com/matthewtakara" rel="noopener noreferrer">
        github.com/matthewtakara
      </a>
    </li>
    <li>
      <span class="label">LinkedIn</span>
      <a href="https://www.linkedin.com/in/matthew-takara" rel="noopener noreferrer">
        linkedin.com/in/matthew-takara
      </a>
    </li>
  </ul>
</BaseLayout>

<style>
  .contact-list {
    list-style: none;
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  li {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
  }

  .label {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    min-width: 5rem;
    flex-shrink: 0;
  }
</style>
