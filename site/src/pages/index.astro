---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home" description="Matthew Takara — civil & environmental engineer and researcher at Carnegie Mellon University.">
  <section class="hero">
    <h1>Matthew Takara</h1>
    <p class="tagline">PhD student and researcher at Carnegie Mellon University. Urban sensing, embedded systems, and sustainable smart city technologies.</p>
  </section>

  <section class="intro">
    <p>
      I build systems that observe the physical world — from analog sensor front-ends
      and multi-node embedded deployments to the data infrastructure and deep learning
      models above them.
    </p>
    <p>
      My research focuses on sustainable and privacy-aware smart city technologies.
    </p>
  </section>

  <nav class="page-links" aria-label="Site sections">
    <a href="/about">About me &rarr;</a>
    <a href="/projects">Projects &rarr;</a>
    <a href="/contact">Get in touch &rarr;</a>
  </nav>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .tagline {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 50ch;
  }

  .intro {
    margin-bottom: var(--space-12);
  }

  .page-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .page-links a {
    font-size: var(--text-base);
    font-weight: 500;
  }
</style>
