---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home" description="Matthew Takara — civil & environmental engineer, researcher, and builder.">
  <section class="hero">
    <h1>Matthew Takara</h1>
    <p class="tagline">Civil &amp; environmental engineer. Researcher in sensing systems. Builder of things that measure the world.</p>
  </section>

  <section class="intro">
    <p>
      I'm a student at Carnegie Mellon University studying civil and environmental engineering,
      with research experience in distributed sensing systems and analog signal conditioning.
    </p>
    <p>
      This site is also a technical project: it tracks and publishes its own energy and carbon
      footprint, rather than claiming to be "green" without evidence.
      <a href="/about#methodology">Read the methodology.</a>
    </p>
  </section>

  <nav class="page-links" aria-label="Site sections">
    <a href="/about">About me &rarr;</a>
    <a href="/projects">Projects &rarr;</a>
    <a href="/contact">Get in touch &rarr;</a>
  </nav>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .tagline {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 50ch;
  }

  .intro {
    margin-bottom: var(--space-12);
  }

  .page-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .page-links a {
    font-size: var(--text-base);
    font-weight: 500;
  }
</style>
